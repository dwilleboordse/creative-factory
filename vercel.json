{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "regions": ["iad1"],
  "functions": {
    "api/analyze.js": { "maxDuration": 300, "memory": 1024 },
    "api/generate.js": { "maxDuration": 300, "memory": 1024 },
    "api/history.js": { "maxDuration": 30, "memory": 1024 },
    "api/data.js": { "maxDuration": 30 }
  }
}
