{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "regions": ["iad1"],
  "functions": {
    "api/generate.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/analyze.js": {
      "maxDuration": 300,
      "memory": 1024
    }
  }
}
